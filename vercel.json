{
  "version": 2,
  "builds": [
    {
      "src": "vercel_app.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.9",
        "buildCommand": "chmod +x vercel_build.sh && ./vercel_build.sh"
      }
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/vercel_app.py" }
  ]
}
